
# Personal AI Employee — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ---------------------------------------------------------------------------
# Gmail Watcher
# ---------------------------------------------------------------------------
# No env vars needed — uses OAuth2 with credentials.json + token.json
# See gmail_watcher.py for setup instructions.

# Optional: Override the Gmail search query
# GMAIL_QUERY=is:unread is:important

# ---------------------------------------------------------------------------
# WhatsApp Watcher
# ---------------------------------------------------------------------------
# Comma-separated keywords to capture (leave empty to capture all messages)
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,meeting

# ---------------------------------------------------------------------------
# LinkedIn Poster
# ---------------------------------------------------------------------------
# Get these from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# NOTE: DRY_RUN is not currently implemented in the codebase.
# Kept here as a placeholder for future use.
# DRY_RUN=true

# Vault root (optional override — defaults to ./Vault)
# VAULT_ROOT=E:/Hackathon_0/Vault
